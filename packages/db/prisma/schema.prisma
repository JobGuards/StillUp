// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  projectMembers ProjectMember[]

  @@index([email])
}

model Project {
  id            String         @id @default(cuid())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  members       ProjectMember[]
  monitors      Monitor[]
  apiKeys       ApiKey[]
  alertChannels AlertChannel[]
  auditLogs     AuditLog[]
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String   // e.g., "MONITOR_CREATE", "PROJECT_DELETE", "LOGIN"
  resourceType String   // e.g., "MONITOR", "PROJECT", "USER"
  resourceId   String?
  userId       String?
  projectId    String?
  metadata     Json?    // Store old/new values or extra context
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([action])
}

model ApiKey {
  id        String    @id @default(cuid())
  projectId String
  key       String    @unique
  name      String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  project   Project   @relation(fields: [projectId], references: [id])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// 5. MONITOR
//
// Core entity. Each monitor represents one job/cron/script being watched.
// heartbeatToken is the secret used in the ping URL: /hb/<heartbeatToken>
// =============================================================================

enum MonitorStatus {
  UP        // Last heartbeat received on time
  DOWN      // Heartbeat missed or failure reported
  DEGRADED  // Late heartbeats detected, job is slow
  PAUSED    // Monitoring explicitly paused by user
}

enum ScheduleType {
  CRON    // Standard cron expression: "0 2 * * *"
  SIMPLE  // Human-readable: "every 5 minutes", "every hour"
}

model Monitor {
  id              String        @id @default(cuid())
  name            String
  description     String?       @db.Text
  schedule        String
  scheduleType    ScheduleType  @default(CRON)
  graceSeconds    Int           @default(300)
  timezone        String        @default("UTC")
  status          MonitorStatus @default(UP)
  heartbeatToken  String        @unique
  enabled         Boolean       @default(true)

  lastHeartbeatAt DateTime?
  nextExpectedAt  DateTime?

  alertOnLate         Boolean @default(true)
  notifyAfterSeconds  Int     @default(0)

  healthScore          Float?
  totalHeartbeats      Int    @default(0)
  consecutiveFailures  Int    @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)

  heartbeats         Heartbeat[]
  incidents          Incident[]
  executionSummaries ExecutionSummary[]
  failurePatterns    FailurePattern[]

  @@index([nextExpectedAt])
  @@index([heartbeatToken])
}

// =============================================================================
// 6. HEARTBEAT
// =============================================================================

enum HeartbeatType {
  SUCCESS
  FAILURE
}

model Heartbeat {
  id              String        @id @default(cuid())
  type            HeartbeatType
  duration        Int?     
  exitCode        Int?
  output          String?       @db.Text
  outputSizeBytes Int?
  metadata        Json?
  isLate          Boolean       @default(false)

  receivedAt     DateTime      @default(now())
  deletedAt      DateTime?

  monitorId      String
  incidentId     String?

  monitor        Monitor   @relation(fields: [monitorId], references: [id])
  incident       Incident? @relation(fields: [incidentId], references: [id])

  @@index([monitorId, receivedAt])
}

// =============================================================================
// 7. INCIDENT
// =============================================================================

// =============================================================================
// 7. INCIDENT
// =============================================================================

model Incident {
  id                 String    @id @default(cuid())
  monitorId          String
  type               String    // "missed", "failed", "late"
  startedAt          DateTime  @default(now())
  resolvedAt         DateTime?
  autoResolved       Boolean   @default(false)
  resolutionNotes    String?   @db.Text
  resolutionCategory String?   // "disk_space" | "permissions" | "network" | "credentials" | "other"
  alertsSent         Int       @default(0)
  groupId            String?

  monitor         Monitor        @relation(fields: [monitorId], references: [id])
  group           IncidentGroup? @relation(fields: [groupId], references: [id])
  heartbeats      Heartbeat[]
  alerts          Alert[]

  @@index([monitorId, startedAt])
  @@index([resolvedAt])
  @@index([groupId])
}

// =============================================================================
// 8. ALERTING
// =============================================================================

model AlertChannel {
  id        String   @id @default(cuid())
  projectId String
  type      String   // "email", "webhook", "telegram", "discord"
  config    Json     // { "email": "...", "url": "..." }
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id])
  alerts    Alert[]

  @@index([projectId, type])
}

model Alert {
  id              String       @id @default(cuid())
  incidentId      String
  channelId       String
  status          String       // "sent", "failed", "pending"
  sentAt          DateTime     @default(now())
  error           String?

  incident        Incident     @relation(fields: [incidentId], references: [id])
  channel         AlertChannel @relation(fields: [channelId], references: [id])

  @@index([incidentId])
}

// =============================================================================
// 9. ANALYTICS (Phase 4)
// =============================================================================

model ExecutionSummary {
  id              String   @id @default(cuid())
  monitorId       String
  date            DateTime // start of day/week (UTC midnight)
  period          String   // "daily" | "weekly"
  totalHeartbeats Int      @default(0)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  lateCount       Int      @default(0)
  avgDuration     Float?
  uptimePercent   Float?   // 0-100
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  monitor Monitor @relation(fields: [monitorId], references: [id])

  @@unique([monitorId, date, period])
  @@index([monitorId, date])
}

// =============================================================================
// 10. FAILURE PATTERNS (Phase 4)
// =============================================================================

model FailurePattern {
  id          String   @id @default(cuid())
  monitorId   String
  type        String   // "time_based" | "duration_anomaly" | "streak" | "degradation"
  description String   @db.Text
  confidence  Float    // 0-1
  metadata    Json?    // e.g. {"hour": 2, "dayOfWeek": 1} for time-based
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  occurrences Int      @default(1)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  monitor Monitor @relation(fields: [monitorId], references: [id])

  @@index([monitorId, type])
  @@index([monitorId, active])
}

// =============================================================================
// 11. INCIDENT GROUPING (Phase 4)
// =============================================================================

model IncidentGroup {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  patternType String?    // "cascade" | "time_based" | "recurring"
  createdAt   DateTime   @default(now())
  resolvedAt  DateTime?
  incidents   Incident[]

  @@index([createdAt])
}
