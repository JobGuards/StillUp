# StillUp Infrastructure Sentinel - Root Environment Configuration

# Database (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stillup?schema=public"

# Backend (Express API)
PORT=4040
JWT_SECRET="generate-a-secure-random-string"
MASTER_ENCRYPTION_KEY="32chars-must-be-long-and-secure-key"
NODE_ENV="development"

# Frontend (Next.js)
FRONTEND_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-another-secure-random-string"

# Notifications & Third Party
DISCORD_WEBHOOK_URL=""
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# StillUp SDK Development (Optional)
STILLUP_API_URL="http://localhost:4040"
STILLUP_API_KEY="sk_test_..."
